; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Puzzle Champ"
config/description="A puzzle game with your own images"
run/main_scene="res://scenes/splash/splash.tscn"
config/features=PackedStringArray("4.6")
config/icon="uid://d1t3bxirl58vs"

[autoload]

GameState="*res://scripts/game_state.gd"
PuzzleConfig="*res://scripts/puzzle_config.gd"
UIScale="*res://scripts/ui_scale.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("gdUnit4")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
